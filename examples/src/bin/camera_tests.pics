# PICS values for the `camera_tests` executable
#
# Covers the Matter 1.5 camera clusters implemented in camera_tests.rs:
#   - CameraAvStreamManagement (AVSM) – video-only
#   - CameraAvSettingsUserLevelManagement (AVSUM) – DPTZ only
#   - ZoneManagement (ZONEMGMT) – 2D-cartesian + user-defined
#   - PushAvStreamTransport (PAVST)
#   - WebRTCTransportProvider (WEBRTCP) – stub (no real ICE/DTLS)
#   - Chime (CHIME)

# -----------------------------------------------------------------------
# Chime cluster (0x0556)
# -----------------------------------------------------------------------
CHIME.S=1
CHIME.S.A0000=1
CHIME.S.A0001=1
CHIME.S.A0002=1
CHIME.S.C00.Rsp=1

# -----------------------------------------------------------------------
# CameraAvStreamManagement (0x0560)
# video + audio features (F00, F01)
# -----------------------------------------------------------------------
AVSM.S=1
AVSM.S.F00=1
AVSM.S.F01=1
AVSM.S.A0000=1
AVSM.S.A0001=1
AVSM.S.A0002=1
AVSM.S.A0003=1
AVSM.S.A0004=1
AVSM.S.A0005=1
AVSM.S.A0006=1
AVSM.S.A0007=1
AVSM.S.A0008=1
AVSM.S.A0009=1
AVSM.S.A000A=1
AVSM.S.A000B=1
AVSM.S.A000C=1
AVSM.S.A000D=1
AVSM.S.A000E=1
AVSM.S.A000F=1
AVSM.S.A0010=1
AVSM.S.A0011=1
AVSM.S.A0012=1
AVSM.S.A0013=1
AVSM.S.A0014=1
AVSM.S.A0016=1
AVSM.S.A0017=1
AVSM.S.A0018=1
AVSM.S.A0019=1
AVSM.S.A001A=1
AVSM.S.A001B=1
AVSM.S.A001C=1
AVSM.S.A001D=1
AVSM.S.A001E=1
AVSM.S.A001F=1
AVSM.S.A0020=1
AVSM.S.A0021=1
AVSM.S.A0022=1
AVSM.S.A0023=1
AVSM.S.A0024=1
AVSM.S.A0025=1
AVSM.S.A0026=1
AVSM.S.A0027=1
AVSM.S.A0028=1

# -----------------------------------------------------------------------
# CameraAvSettingsUserLevelManagement (0x0561) – DPTZ only (F02)
# -----------------------------------------------------------------------
AVSUM.S=1
AVSUM.S.F02=1

# -----------------------------------------------------------------------
# ZoneManagement (0x0550)
# -----------------------------------------------------------------------
ZONEMGMT.S=1
ZONEMGMT.S.F00=1
ZONEMGMT.S.F01=1

# -----------------------------------------------------------------------
# PushAvStreamTransport (0x0555)
# -----------------------------------------------------------------------
PAVST.S=1

# -----------------------------------------------------------------------
# WebRTCTransportProvider (0x0553) – stub
# -----------------------------------------------------------------------
WEBRTCP.S=1
WEBRTCP.S.A0000=1
WEBRTCP.S.C00.Rsp=1
WEBRTCP.S.C02.Rsp=1
WEBRTCP.S.C04.Rsp=1
WEBRTCP.S.C05.Rsp=1
WEBRTCP.S.C06.Rsp=1
WEBRTCP.S.C01.Tx=1
WEBRTCP.S.C03.Tx=1